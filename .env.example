# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored so your credentials never get committed.

# --- UIT LMS credentials (required) ---
UIT_USERNAME=your_uit_username
UIT_PASSWORD=your_uit_password

# --- LMS endpoints (optional overrides) ---
# UIT_BASE_URL=https://lms.uit.edu.mm
# UIT_LOGIN_URL=https://lms.uit.edu.mm/login/index.php

# --- Redis (stores per-file content hashes to detect updates) ---
REDIS_URL=redis://localhost:6379/0
# UIT_REDIS_NAMESPACE=uit:lecture

# --- Local download location ---
# UIT_DOWNLOAD_DIR=downloads

# --- Behaviour ---
# Set to true only if the LMS certificate is valid.
# UIT_VERIFY_SSL=false
# Seconds to wait between requests (be gentle with the server).
# UIT_REQUEST_DELAY=1.0

# --- Telegram bot (required for bot.py) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Chat that receives the lectures. Also the only chat allowed to command the
# bot. Get it by messaging your bot then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
# Daily run times in the server's local time, comma-separated HH:MM.
# Leave empty for command-only (no automatic runs).
UIT_SCHEDULE_TIMES=08:00,18:00
# Max file size (MB) to upload to Telegram (bot API limit is 50).
# TELEGRAM_MAX_FILE_MB=50
